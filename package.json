{
  "name": "eslint",
  "version": "10.0.0",
  "description": "A pluggable and configurable linter tool for identifying and reporting on patterns in JavaScript.",
  "type": "commonjs",
  "main": "./lib/api.js",
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "default": "./lib/api.js"
    },
    "./config": {
      "types": "./lib/types/config-api.d.ts",
      "default": "./lib/config-api.js"
    },
    "./use-at-your-own-risk": {
      "types": "./lib/types/use-at-your-own-risk.d.ts",
      "default": "./lib/unsupported-api.js"
    },
    "./universal": {
      "types": "./lib/types/universal.d.ts",
      "default": "./lib/universal.js"
    },
    "./rules": {
      "types": "./lib/types/rules.d.ts"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "eslint": "./bin/eslint.js"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "files": [
    "bin/",
    "conf/",
    "lib/",
    "messages/",
    "native/src/",
    "native/Cargo.toml",
    "native/build.rs",
    "native/*.node",
    "scripts/build-native.sh"
  ],
  "dependencies": {
    "espree": "^10.3.0",
    "eslint-scope": "^8.3.0",
    "eslint-visitor-keys": "^4.2.0",
    "esquery": "^1.6.0",
    "esutils": "^2.0.3",
    "ajv": "^6.12.6",
    "minimatch": "^9.0.5",
    "glob-parent": "^6.0.2",
    "optionator": "^0.9.4",
    "debug": "^4.3.7",
    "fast-deep-equal": "^3.1.3",
    "natural-compare": "^1.4.0",
    "escape-string-regexp": "^4.0.0",
    "json-stable-stringify-without-jsonify": "^1.0.1",
    "ignore": "^5.3.2",
    "find-up": "^5.0.0",
    "file-entry-cache": "^8.0.0",
    "imurmurhash": "^0.1.4",
    "cross-spawn": "^7.0.6",
    "chalk": "^4.1.2",
    "strip-ansi": "^6.0.1",
    "glob": "^10.4.5",
    "@eslint/config-helpers": "^0.2.1"
  },
  "peerDependencies": {
    "jiti": ">=1.21.0"
  },
  "peerDependenciesMeta": {
    "jiti": {
      "optional": true
    }
  },
  "devDependencies": {
    "mocha": "^10.8.2",
    "chai": "^4.5.0",
    "sinon": "^17.0.2"
  },
  "scripts": {
    "build:native": "bash scripts/build-native.sh",
    "test": "mocha tests/ --recursive --timeout 10000",
    "lint": "node bin/eslint.js lib/"
  },
  "keywords": [
    "ast",
    "lint",
    "javascript",
    "ecmascript",
    "espree"
  ],
  "license": "MIT"
}
